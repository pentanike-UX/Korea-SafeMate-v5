    "check": "tsc --noEmit && eslint \"src/components/v4/**/*.{ts,tsx}\" \"src/components/route-curated/**/*.{ts,tsx}\" \"src/components/maps/**/*.{ts,tsx}\" \"src/components/map-shell/**/*.{ts,tsx}\" \"src/components/app-shell/**/*.{ts,tsx}\" \"src/components/explore/explore-workspace-client.tsx\" \"src/components/explore/spot-detail-workspace-client.tsx\" \"src/components/explore/story-detail-workspace-client.tsx\" \"src/lib/v4/explore-workspace-payload.ts\" \"src/data/v4/**/*.{ts,tsx}\" \"src/domain/**/*.ts\" \"src/lib/v4/**/*.ts\" \"src/lib/route-curated/**/*.ts\" \"src/lib/routing/**/*.ts\" \"src/lib/maps/**/*.ts\" \"src/app/api/routing/**/*.ts\" \"src/components/admin/curated-routes-admin-client.tsx\" \"src/components/admin/admin-prompt-policy-client.tsx\" \"src/components/admin/admin-localization-client.tsx\" \"src/components/admin/admin-publish-panel-client.tsx\" \"src/components/mypage/guardian-availability-client.tsx\" \"src/components/home/**/*.{ts,tsx}\" \"src/components/layout/site-footer.tsx\" \"src/components/layout/public-site-shell.tsx\"",
    "preview": "next build && next start",
    "deploy": "bash deploy.sh",
    "deploy:skip-migration": "bash deploy.sh --skip-migration",
    "deploy:skip-push": "bash deploy.sh --skip-push"
  },
  "dependencies": {
