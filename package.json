    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.142",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.21.0",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "react": "19.2.4",
